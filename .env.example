# =============================================================================
# Variables del FRONTEND (Vite, prefijo VITE_ requerido para que se embeben
# en el bundle del cliente). Estas se configuran también en Vercel.
# =============================================================================

VITE_SUPABASE_URL=https://aabtbwmtnhtzjdzqdvil.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Mismo valor que API_SECRET_KEY. Se envía en x-api-key al llamar a
# /api/registrar-toma. Como se embebe en el bundle JS, es una "llave
# compartida del hogar", no una credencial por usuario.
VITE_API_KEY=cambia-esto-por-algo-largo-y-aleatorio

# =============================================================================
# Variables del BACKEND (Vercel Functions, NO requieren prefijo).
# =============================================================================

# Supabase
SUPABASE_URL=https://aabtbwmtnhtzjdzqdvil.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Web Push VAPID. Genera con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BPd...
VAPID_PRIVATE_KEY=abc...
VAPID_SUBJECT=mailto:tu-email@ejemplo.com

# API key para /api/registrar-toma y trigger manual del cron
API_SECRET_KEY=cambia-esto-por-algo-largo-y-aleatorio
